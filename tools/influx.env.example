# Copy to tools/influx.env (gitignored) and fill in the password.
# tools/export_history.py loads this file if present; real environment
# variables of the same name always take priority over the file.
#
# NEVER commit tools/influx.env or put the password in any tracked file --
# this repo is public on GitHub.

INFLUX_URL=http://localhost:8086
INFLUX_USER=readonly
INFLUX_DB=hass
INFLUX_PASSWORD=changeme
